{
  "name": "plainfp-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo root for plainfp.",
  "license": "MIT",
  "author": "Konstantinos Paparas <kelsos86@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kelsos/plainfp.git"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:watch": "pnpm --filter plainfp test:watch",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "check": "pnpm -r run check",
    "release": "pnpm --filter plainfp release",
    "coverage": "pnpm -r run coverage",
    "bench": "pnpm --filter plainfp run bench",
    "docs": "pnpm --filter plainfp run docs",
    "commitlint": "commitlint"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "changelogen": "0.6.2"
  }
}
