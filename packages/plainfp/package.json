{
  "name": "plainfp",
  "version": "0.0.1",
  "description": "A plain, readable functional programming library for TypeScript — Result, Option, and friends, without the category theory.",
  "keywords": [
    "fp",
    "functional",
    "option",
    "pipe",
    "result",
    "typescript"
  ],
  "homepage": "https://github.com/kelsos/plainfp#readme",
  "bugs": {
    "url": "https://github.com/kelsos/plainfp/issues"
  },
  "license": "MIT",
  "author": "Konstantinos Paparas <kelsos86@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kelsos/plainfp.git",
    "directory": "packages/plainfp"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pipe": {
      "types": "./dist/pipe.d.ts",
      "import": "./dist/pipe.js"
    },
    "./result": {
      "types": "./dist/result/index.d.ts",
      "import": "./dist/result/index.js"
    },
    "./result-async": {
      "types": "./dist/result-async/index.d.ts",
      "import": "./dist/result-async/index.js"
    },
    "./option": {
      "types": "./dist/option/index.d.ts",
      "import": "./dist/option/index.js"
    },
    "./arrays": {
      "types": "./dist/arrays/index.d.ts",
      "import": "./dist/arrays/index.js"
    },
    "./records": {
      "types": "./dist/records/index.d.ts",
      "import": "./dist/records/index.js"
    },
    "./strings": {
      "types": "./dist/strings/index.d.ts",
      "import": "./dist/strings/index.js"
    },
    "./predicates": {
      "types": "./dist/predicates/index.d.ts",
      "import": "./dist/predicates/index.js"
    },
    "./functions": {
      "types": "./dist/functions/index.d.ts",
      "import": "./dist/functions/index.js"
    },
    "./brand": {
      "types": "./dist/brand/index.d.ts",
      "import": "./dist/brand/index.js"
    },
    "./non-empty-array": {
      "types": "./dist/non-empty-array/index.d.ts",
      "import": "./dist/non-empty-array/index.js"
    },
    "./tagged": {
      "types": "./dist/tagged/index.d.ts",
      "import": "./dist/tagged/index.js"
    },
    "./interop/zod": {
      "types": "./dist/interop/zod/index.d.ts",
      "import": "./dist/interop/zod/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test",
    "test:watch": "vp test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "vp lint",
    "format": "vp fmt",
    "check": "vp check",
    "coverage": "vp test --coverage",
    "bench": "vp test bench --run",
    "attw": "pnpm dlx @arethetypeswrong/cli@0.18.2 --pack . --profile esm-only",
    "release": "changelogen --release --push"
  },
  "devDependencies": {
    "@codspeed/vitest-plugin": "5.3.0",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.4",
    "@voidzero-dev/vite-plus-core": "0.1.18",
    "typescript": "6.0.3",
    "vite-plus": "0.1.18",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "zod": "^3.22.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
